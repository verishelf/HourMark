# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe (publishable key only — safe for Expo app)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional override. Defaults to ${EXPO_PUBLIC_SUPABASE_URL}/functions/v1
EXPO_PUBLIC_API_URL=https://your-project.supabase.co/functions/v1

# Wire transfer instructions (shown to buyers at checkout)
EXPO_PUBLIC_WIRE_BANK_NAME=Chase Bank, N.A.
EXPO_PUBLIC_WIRE_ACCOUNT_NAME=HourMark Inc.
EXPO_PUBLIC_WIRE_ROUTING=021000021
EXPO_PUBLIC_WIRE_ACCOUNT=your-account-number
EXPO_PUBLIC_WIRE_SWIFT=CHASUS33
EXPO_PUBLIC_WIRE_BANK_ADDRESS=383 Madison Avenue, New York, NY 10179, USA

# Supabase Edge Function secrets (set via `supabase secrets set`)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
