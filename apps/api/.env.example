# Server
PORT=3001
NODE_ENV=development

# Stripe (server-side only — never expose in Expo app)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase (service role for webhooks + server writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HourMark platform commission (default 3%)
PLATFORM_COMMISSION_RATE=0.03

# Connect onboarding return URLs (optional overrides)
STRIPE_CONNECT_REFRESH_URL=hourmark://profile
STRIPE_CONNECT_RETURN_URL=hourmark://profile
